# MoRA Research Console — environment for docker compose.
# Copy to `.env` in this directory and fill in real values:  cp .env.example .env
# NEVER commit the real .env (it is gitignored).

# --- session signing key (REQUIRED) ---
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# --- seeded admin login (REQUIRED) ---
# The admin user is (re)created from these on every boot.
APP_ADMIN_USER=admin
APP_ADMIN_PASSWORD=change-me-strong-password

# --- Postgres (REQUIRED in Docker; the app uses SQLite only when DATABASE_URL is unset) ---
POSTGRES_USER=mora
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=mora
# DATABASE_URL is assembled from the above in docker-compose.yml; override it here if needed.

# --- optional ---
# SESSION_MAX_AGE=28800     # session lifetime in seconds (default 8h)
